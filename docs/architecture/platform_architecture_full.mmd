    classDef experimental fill:#fff7df,stroke:#a06b00,stroke-width:1.4px,color:#172033;
    class Configs,Data,Registry,Loader,Cleaning,Features,ML,Strategies,Portfolio,Backtesting,Validation,Experiments,Visualisation,Reporting,Reports implemented;
    class LLM experimental;
